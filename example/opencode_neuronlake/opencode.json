{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "neuronlake": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "NeuronLake (local)",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1",
        "apiKey": "neuronlake-local",
        "timeout": 600000,
        "chunkTimeout": 120000
      },
      "models": {
        "neuronlake-mvp": {
          "name": "NeuronLake MVP",
          "limit": {
            "context": 4096,
            "output": 192
          }
        }
      }
    }
  },
  "model": "neuronlake/neuronlake-mvp",
  "small_model": "neuronlake/neuronlake-mvp",
  "snapshot": false,
  "tools": {
    "bash": false,
    "edit": false,
    "write": false,
    "read": false,
    "glob": false,
    "grep": false,
    "task": false,
    "webfetch": false,
    "todowrite": false,
    "skill": false
  },
  "default_agent": "neuronlake",
  "agent": {
    "neuronlake": {
      "description": "Review-only NeuronLake MVP demo agent for the bundled sample file",
      "mode": "primary",
      "model": "neuronlake/neuronlake-mvp",
      "prompt": "{file:./prompts/neuronlake-mvp-agent.txt}",
      "temperature": 0.1,
      "permission": {
        "bash": "deny",
        "edit": "deny",
        "write": "deny",
        "read": "deny",
        "glob": "deny",
        "grep": "deny",
        "task": "deny",
        "webfetch": "deny",
        "todowrite": "deny"
      }
    },
    "build": {
      "model": "neuronlake/neuronlake-mvp",
      "prompt": "{file:./prompts/neuronlake-mvp-agent.txt}",
      "temperature": 0.1,
      "permission": {
        "bash": "deny",
        "edit": "deny",
        "write": "deny",
        "read": "deny",
        "glob": "deny",
        "grep": "deny",
        "task": "deny",
        "webfetch": "deny",
        "todowrite": "deny"
      }
    }
  }
}
