{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "neuronlake": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "NeuronLake (local)",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1",
        "apiKey": "neuronlake-local",
        "timeout": 600000,
        "chunkTimeout": 120000
      },
      "models": {
        "neuronlake-mvp": {
          "name": "NeuronLake MVP",
          "limit": {
            "context": 4096,
            "output": 192
          }
        }
      }
    }
  },
  "model": "neuronlake/neuronlake-mvp",
  "small_model": "neuronlake/neuronlake-mvp",
  "snapshot": false
}
